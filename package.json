{
  "name": "eddyq-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "eddyq — Rust + Postgres job queue with first-class Node bindings",
  "repository": "https://github.com/remstone7/eddyq",
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "docs:api": "rm -rf docs/public/api && pnpm --filter @eddyq/queue docs && pnpm --filter @eddyq/nestjs docs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm docs:api && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "typedoc": "^0.28.3",
    "@typhonjs-typedoc/typedoc-theme-dmt": "^0.4.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.1"
  }
}
