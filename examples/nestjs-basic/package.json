{
  "name": "@eddyq/example-nestjs-basic",
  "version": "0.0.0",
  "private": true,
  "description": "Minimal NestJS app wired to @eddyq/nestjs — processors, scheduled jobs, HTTP enqueue.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start:api": "node --enable-source-maps dist/main.js",
    "start:worker": "node --enable-source-maps dist/worker.js",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@eddyq/board": "workspace:*",
    "@eddyq/nestjs": "workspace:*",
    "@eddyq/queue": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20"
  }
}
