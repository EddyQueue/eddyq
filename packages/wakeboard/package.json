{
  "name": "@eddyq/wakeboard",
  "version": "0.0.1",
  "private": true,
  "description": "eddyq-wakeboard — Svelte admin dashboard for eddyq, mountable as a NestJS module",
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "build:frontend": "vite build",
    "build:nestjs": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "dev:frontend": "vite",
    "test": "echo \"no tests yet\" && exit 0"
  },
  "dependencies": {
    "@eddyq/nestjs": "workspace:*",
    "@eddyq/queue": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^20",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "svelte": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10",
    "@nestjs/core": ">=10",
    "express": ">=4"
  },
  "engines": {
    "node": ">=20"
  }
}
