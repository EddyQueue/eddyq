{
  "name": "@eddyq/queue",
  "version": "0.0.1",
  "description": "Node.js client for eddyq — a Rust + Postgres job queue",
  "license": "(MIT OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EddyQueue/eddyq.git",
    "directory": "packages/queue"
  },
  "homepage": "https://github.com/EddyQueue/eddyq",
  "main": "lib.cjs",
  "types": "lib.d.ts",
  "files": [
    "index.js",
    "index.d.ts",
    "lib.cjs",
    "lib.d.ts",
    "README.md"
  ],
  "napi": {
    "binaryName": "eddyq",
    "packageName": "@eddyq/queue",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --manifest-path=../../Cargo.toml --package eddyq-napi --output-dir .",
    "build:debug": "napi build --platform --manifest-path=../../Cargo.toml --package eddyq-napi --output-dir .",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "typecheck": "tsc --noEmit lib.d.ts",
    "test": "echo \"no tests yet\" && exit 0",
    "lint": "echo \"no lint yet\" && exit 0",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "pg": "^8.20.0",
    "typedoc": "^0.28.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
